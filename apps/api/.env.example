# Real LLM providers (optional — mock models work without these)
# Add OPENAI_API_KEY to unlock the openai-gpt4o model
OPENAI_API_KEY=

# Add ANTHROPIC_API_KEY to unlock the anthropic-claude model
ANTHROPIC_API_KEY=

# Nebius AI Studio (OpenAI-compatible token factory endpoint)
# Add NEBIUS_API_KEY to unlock the nebius model
NEBIUS_API_KEY=
# Override the model (defaults to meta-llama/Meta-Llama-3.1-70B-Instruct)
NEBIUS_MODEL=
# Override the base URL (defaults to https://api.studio.nebius.ai/v1/)
NEBIUS_BASE_URL=

# LangSmith tracing (optional)
# Create a free account at https://smith.langchain.com to get an API key
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=recommendation-evals
