# Real LLM providers (optional — mock models work without these)
# Add OPENAI_API_KEY to unlock the openai-gpt4o model
OPENAI_API_KEY=

# Add ANTHROPIC_API_KEY to unlock the anthropic-claude model
ANTHROPIC_API_KEY=

# LangSmith tracing (optional)
# Create a free account at https://smith.langchain.com to get an API key
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=recommendation-evals
